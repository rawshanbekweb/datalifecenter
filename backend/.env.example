DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/datalife?schema=public"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# --- Production (Render) uchun ---
# DATABASE_URL  = Render Postgres'ning "Internal Database URL"i
# NODE_ENV      = production   (majburiy: xato tafsilotlari mijozga chiqmasligi uchun)
# FRONTEND_URL  = https://datalifecenter.vercel.app
# JWT_SECRET    = kamida 32 belgili tasodifiy qiymat (server production'da tekshiradi),
#                 yaratish: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Build Command = npm install && npm run build && npx prisma migrate deploy
# Start Command = npm start
