# --- Majburiy sozlamalar ---
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/datalife?schema=public"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# --- Email (ixtiyoriy) ---
# Sozlanmasa email yuborilmaydi (dev'da xat mazmuni konsolga chiqadi).
# Brevo (brevo.com) HTTP API orqali yuboriladi — SMTP relay'dan farqli
# o'laroq IP manzil cheklovi yo'q, shuning uchun Render kabi o'zgaruvchan-IP
# hostingda ham qayta deploy'dan keyin qo'shimcha sozlash shart emas.
# BREVO_API_KEY: Brevo dashboard → SMTP & API → API Keys → Generate a new API key
# EMAIL_FROM: "Nomi <email>" — email Brevo'da "Senders" sifatida tasdiqlangan bo'lishi shart
BREVO_API_KEY=
EMAIL_FROM="DATA LIFE <no-reply@datalife.uz>"

# --- Cloudinary (ixtiyoriy, lekin Render/Railway'da MAJBURIY) ---
# Ephemeral hostingda lokal disk har deploy'da tozalanadi — yuklangan
# rasm/videolar yo'qoladi. cloudinary.com'da bepul hisob oching va
# Dashboard'dagi qiymatlarni shu yerga qo'ying.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Sentry (ixtiyoriy) ---
# Production'da xatolarni kuzatish: sentry.io'da bepul loyiha oching,
# DSN'ni shu yerga qo'ying. Bo'sh qolsa Sentry yoqilmaydi.
SENTRY_DSN=

# --- Production (Render) uchun eslatma ---
# DATABASE_URL  = Render Postgres'ning "Internal Database URL"i
# NODE_ENV      = production   (majburiy: xato tafsilotlari mijozga chiqmasligi uchun)
# FRONTEND_URL  = https://datalifecenter.vercel.app
# JWT_SECRET    = kamida 32 belgili tasodifiy qiymat (server production'da tekshiradi),
#                 yaratish: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# CLOUDINARY_*  = to'ldirilishi shart (yuqoridagi izohga qarang)
# BREVO_API_KEY va EMAIL_FROM = email ishlashi uchun to'ldirilishi shart (yuqoridagi izohga qarang)
# Build Command = npm install && npm run build && npx prisma migrate deploy
# Start Command = npm start
#
# Production'da seed kerak bo'lsa (demo parollar bloklanadi):
# SEED_FORCE=true ADMIN_PASSWORD=<kuchli parol> npm run seed
