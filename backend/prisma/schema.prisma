generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ContentType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  FREE
  UNPAID
  PENDING
  PAID
  REJECTED
  REFUNDED
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  phone        String?
  role         Role         @default(STUDENT)
  isBlocked    Boolean      @default(false)
  avatarUrl    String?
  // Parol o'zgarganda oshiriladi — eski JWT sessiyalari darhol bekor bo'ladi
  tokenVersion Int          @default(0)
  emailVerifiedAt DateTime?
  mentorProfile Mentor?
  enrollments  Enrollment[]
  lessonProgress LessonProgress[]
  lessonQuestions LessonQuestion[]
  courseReviews CourseReview[]
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Email tasdiqlash — parol tiklash bilan bir xil naqsh (faqat hash saqlanadi)
model EmailVerificationToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Parolni tiklash: xom token emas, faqat sha256 hash saqlanadi
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Mentor {
  id            String   @id @default(cuid())
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?  @unique
  name          String
  bio           String
  photoUrl      String?
  specialty     String
  position      String?
  linkedinUrl   String?
  githubUrl     String?
  telegramUrl   String?
  order         Int      @default(0)
  featured      Boolean  @default(false)
  courses       Course[]
  blogPosts     BlogPost[]
  liveSessions  LiveSession[]
  requests      MentorRequest[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Course {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  subtitle       String?
  description    String
  iconKey        String
  color          String
  bg             String
  border         String
  price          Decimal?
  isFree         Boolean      @default(true)
  currency       String       @default("UZS")
  durationMonths Int
  level          Level        @default(BEGINNER)
  rating         Float        @default(0)
  reviewsCount   Int          @default(0)
  studentsCount  Int          @default(0)
  tags           String[]
  published      Boolean      @default(false)
  mentor         Mentor?      @relation(fields: [mentorId], references: [id])
  mentorId       String?
  modules        Module[]
  enrollments    Enrollment[]
  liveSessions   LiveSession[]
  announcements  Announcement[]
  reviews        CourseReview[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model CourseReview {
  id        String   @id @default(cuid())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  rating    Int
  comment   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}

model LiveSession {
  id          String        @id @default(cuid())
  title       String
  description String?
  meetingUrl  String
  startsAt    DateTime
  durationMin Int           @default(60)
  status      SessionStatus @default(SCHEDULED)
  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  mentor      Mentor        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId    String
  // Bo'sh massiv = kursga yozilgan barcha faol o'quvchiga ochiq (standart).
  // To'ldirilsa — faqat shu userId'lar ko'radi (mentor aniq o'quvchilarni tanlagan).
  targetStudentIds String[] @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([courseId, startsAt])
}

model Module {
  id          String   @id @default(cuid())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  title       String
  description String?
  order       Int
  lessons     Lesson[]
}

model Lesson {
  id              String      @id @default(cuid())
  module          Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId        String
  title           String
  order           Int
  contentType     ContentType @default(VIDEO)
  videoUrl        String?
  content         String?
  durationMinutes Int?
  isFreePreview   Boolean     @default(false)
  progress        LessonProgress[]
  questions       LessonQuestion[]
}

// O'quvchi ↔ mentor muloqoti: dars ostidagi savol-javob
model LessonQuestion {
  id         String    @id @default(cuid())
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId   String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  body       String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([lessonId, createdAt])
  @@index([userId])
}

enum MentorRequestStatus {
  OPEN
  ANSWERED
  CLOSED
}

// Mentor ↔ admin aloqasi: mentorning rasmiy so'rovlari
model MentorRequest {
  id        String              @id @default(cuid())
  mentor    Mentor              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId  String
  subject   String
  body      String
  status    MentorRequestStatus @default(OPEN)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([mentorId])
}

enum NotificationType {
  QUESTION_ANSWERED
  NEW_QUESTION
  ENROLLMENT_ACTIVATED
  RECEIPT_SUBMITTED
  MENTOR_REQUEST_REPLIED
  NEW_MENTOR_REQUEST
  SESSION_SCHEDULED
  ANNOUNCEMENT
  PAYMENT_REJECTED
}

// Kabinet ichidagi bildirishnomalar — har bir yozuv bitta foydalanuvchiga tegishli
model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum AnnouncementAudience {
  ALL
  STUDENTS
  MENTORS
}

// Admin e'lonlari — yaratilganda auditoriyaga Notification sifatida tarqatiladi
model Announcement {
  id        String               @id @default(cuid())
  title     String
  body      String
  audience  AnnouncementAudience @default(ALL)
  course    Course?              @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId  String?
  createdAt DateTime             @default(now())
}

model LessonProgress {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String?
  category   String
  order      Int      @default(0)
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Project {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String
  techStack     String[]
  screenshotUrl String
  liveUrl       String?
  repoUrl       String?
  // true bo'lsa kartada skrinshot o'rniga liveUrl to'g'ridan-to'g'ri iframe orqali
  // "jonli" ko'rsatiladi — ba'zi saytlar (X-Frame-Options/CSP) buni bloklashi mumkin,
  // shu holatlarda admin buni o'chirib skrinshotga qaytishi kerak.
  liveEmbed     Boolean  @default(false)
  order         Int      @default(0)
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Enrollment {
  id              String               @id @default(cuid())
  user            User                 @relation(fields: [userId], references: [id])
  userId          String
  course          Course               @relation(fields: [courseId], references: [id])
  courseId        String
  status          EnrollmentStatus     @default(PENDING)
  paymentStatus   PaymentStatus        @default(UNPAID)
  provider        String?
  providerRef     String?
  amountPaid      Decimal?
  receiptUrl      String?
  rejectionReason String?
  enrolledAt      DateTime             @default(now())
  completedAt     DateTime?
  transactions    PaymentTransaction[]

  @@unique([userId, courseId])
}

enum PaymentProvider {
  CLICK
  PAYME
}

enum PaymentTxState {
  CREATED
  PERFORMED
  CANCELLED
  CANCELLED_AFTER_PERFORM
}

// Payme/Click webhook'lari orqali keladigan to'lov shlyuzi tranzaksiyasi holati.
// Ikkala protokol ham idempotentlikni talab qiladi — bir xil so'rov qayta kelsa
// bir xil javob qaytarilishi SHART, shuning uchun holat alohida saqlanadi.
model PaymentTransaction {
  id           String          @id @default(cuid())
  provider     PaymentProvider
  providerTxId String
  enrollment   Enrollment      @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  amount       Decimal
  state        PaymentTxState  @default(CREATED)
  reason       Int?
  createTime   DateTime        @default(now())
  performTime  DateTime?
  cancelTime   DateTime?

  @@unique([provider, providerTxId])
  @@index([enrollmentId])
}

// Bosh sahifa bo'limlari (hero_stats, about, services, why_us, contact) uchun
// admin tomonidan tahrirlanadigan tarkib — har bir bo'lim JSON blob sifatida saqlanadi.
model SiteSetting {
  id        String   @id @default(cuid())
  section   String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  avatarUrl String?
  text      String
  rating    Int      @default(5)
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())
}

model BlogPost {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  excerpt      String
  content      String
  category     String
  iconKey      String
  color        String
  bg           String
  border       String
  readMinutes  Int       @default(5)
  views        Int       @default(0)
  tags         String[]
  published    Boolean   @default(false)
  mentor       Mentor?   @relation(fields: [mentorId], references: [id])
  mentorId     String?
  publishedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
